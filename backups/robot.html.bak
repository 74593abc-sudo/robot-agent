<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="UTF-8">
<title>灵珑</title>
<style>
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:150px;height:180px;background:transparent;overflow:hidden;user-select:none}

:root{
  --accent:#74F6E8;
  --accent-soft:rgba(116,246,232,.5);
}

#wrap{
  width:150px;height:180px;cursor:grab;position:relative;
  display:flex;align-items:center;justify-content:center;
  perspective:600px;
}
#wrap.dragging{cursor:grabbing}
#rotate-wrap{
  transform-style:preserve-3d;
  transition:transform .45s cubic-bezier(.22,.61,.36,1);
}
#robot-svg{
  width:144px;height:172px;overflow:visible;display:block;
  filter:drop-shadow(0 8px 16px rgba(0,0,0,.5));
  transition:filter .6s ease;
  transform-origin:center bottom;
}
#wrap:hover #robot-svg{
  filter:drop-shadow(0 10px 20px rgba(0,0,0,.55))
         drop-shadow(0 0 14px var(--accent-soft));
}

/* ── peek (edge-rest) postures ─ 趴在边框: lean / drape on the edge ── */
/* Body anchored beyond the off-screen edge; head leans into view with a
   gentle idle breathing motion so it feels alive, not just "hidden". */
.peek-r #robot-svg{
  transform-origin:92% 62%;
  animation:peekRestR 4.4s ease-in-out infinite;
}
@keyframes peekRestR{
  0%,100%{transform:rotate(-26deg) translate(-6px,3px) scale(.95)}
  50%    {transform:rotate(-22deg) translate(-4px,1px) scale(.96)}
}
.peek-l #robot-svg{
  transform-origin:8% 62%;
  animation:peekRestL 4.4s ease-in-out infinite;
}
@keyframes peekRestL{
  0%,100%{transform:rotate(26deg) translate(6px,3px) scale(.95)}
  50%    {transform:rotate(22deg) translate(4px,1px) scale(.96)}
}
/* Bottom edge: robot rests on the bottom with only head/upper body above,
   gentle side-to-side rocking like it's curiously looking around. */
.peek-b #robot-svg{
  transform-origin:50% 95%;
  animation:peekRestB 5s ease-in-out infinite;
}
@keyframes peekRestB{
  0%,100%{transform:translateY(-4px) rotate(-2.5deg) scale(.96)}
  50%    {transform:translateY(-2px) rotate(2.5deg) scale(.96)}
}
/* Top edge: robot is draped over the top, lower body slipping into view
   with a slight pendulum sway as if dangling. */
.peek-t #robot-svg{
  transform-origin:50% 5%;
  animation:peekRestT 5s ease-in-out infinite;
}
@keyframes peekRestT{
  0%,100%{transform:translateY(4px) rotate(2.5deg) scale(.96)}
  50%    {transform:translateY(2px) rotate(-2.5deg) scale(.96)}
}

/* ── hero entrance (first launch) ────────────────────────────── */
.s-hero #robot-svg{
  animation:heroIn 2.6s cubic-bezier(.22,.61,.36,1) both;
  filter:drop-shadow(0 12px 28px rgba(0,0,0,.6))
         drop-shadow(0 0 30px var(--accent-soft))
         drop-shadow(0 0 50px var(--accent-soft));
}
@keyframes heroIn{
  0%  {opacity:0;transform:scale(.2) rotate(-18deg)}
  35% {opacity:1;transform:scale(1.18) rotate(6deg)}
  60% {transform:scale(.95) rotate(-3deg)}
  100%{opacity:1;transform:scale(1) rotate(0)}
}

/* ── idle micro-actions (random, brief) ──────────────────────── */
.mc-lookup .eye-shine{transform:translateY(-2px)}
.mc-lookdown .eye-shine{transform:translateY(2px)}
.mc-wink-l .eye-base:first-of-type,
.mc-wink-l .eye-shine:first-of-type{animation:winkClose .55s ease-in-out}
.mc-wink-r .eye-base:last-of-type,
.mc-wink-r .eye-shine:last-of-type{animation:winkClose .55s ease-in-out}
.mc-tilt #robot-svg{transform:rotate(-3deg);transform-origin:50% 75%;transition:transform .8s ease-in-out}
.mc-tilt-r #robot-svg{transform:rotate(3deg);transform-origin:50% 75%;transition:transform .8s ease-in-out}
.mc-bob #body-float{animation-duration:1.4s !important}
.mc-nod #body-group{animation:nod .6s ease-in-out}
.mc-yawn .mouth-happy{animation:yawn 1.8s ease-in-out}
.mc-look-left .eye-base,.mc-look-left .eye-shine{transform:translateX(-2.5px);transition:transform .3s ease}
.mc-look-right .eye-base,.mc-look-right .eye-shine{transform:translateX(2.5px);transition:transform .3s ease}
.mc-curious .eye-base{transform-box:fill-box;transform-origin:center;transform:scale(1.2);transition:transform .2s ease}
.mc-curious .gem-glow{animation-duration:1.2s !important}
@keyframes winkClose{0%,100%{transform:scaleY(1)}30%,55%{transform:scaleY(.1)}}
@keyframes nod{0%,100%{transform:rotate(0)}30%{transform:rotate(3deg)}70%{transform:rotate(-2deg)}}
@keyframes yawn{0%,100%{d:path("M 60 72 Q 65 77 70 72")}30%,70%{d:path("M 58 71 Q 65 80 72 71")}}

/* ── state-driven effects (no CSS transforms on SVG groups) ── */
.s-sleeping{filter:brightness(.55) saturate(.45)}
.s-sleeping .gem-glow{opacity:.25!important}

.s-thinking .eye-base,.s-thinking .eye-shine{
  transform-box:fill-box;transform-origin:center;
  animation:blink 1.7s ease-in-out infinite
}
.s-speaking .mouth-speaking{animation:talk .32s steps(2) infinite}

/* Working state: shimmering gear + faster blink */
.s-working .eye-base,.s-working .eye-shine{
  transform-box:fill-box;transform-origin:center;
  animation:blink 1.1s ease-in-out infinite
}
.s-working #work-gears{display:block}
#work-gears{display:none}
.s-working #gear-l{animation:spinL 2.4s linear infinite;transform-origin:38px 34px;transform-box:fill-box}
.s-working #gear-r{animation:spinR 1.8s linear infinite;transform-origin:92px 36px;transform-box:fill-box}
@keyframes spinL{from{transform:rotate(0)}to{transform:rotate(360deg)}}
@keyframes spinR{from{transform:rotate(0)}to{transform:rotate(-360deg)}}

.s-notification .eye-base{
  transform-box:fill-box;transform-origin:center;transform:scale(1.2)
}
.s-notification #body-group{
  animation:bounce .7s ease-in-out 4
}

@keyframes blink{0%,88%,100%{transform:scaleY(1)}94%{transform:scaleY(.15)}}
@keyframes talk{0%{d:path("M 60 72 Q 65 75 70 72 Q 65 73 60 72 Z")}50%{d:path("M 60 71 Q 65 77 70 71 Q 65 74 60 71 Z")}}
@keyframes bounce{0%,100%{transform:translateY(0)}25%{transform:translateY(-16px)}50%{transform:translateY(-3px)}75%{transform:translateY(-10px)}}

/* mouth + eye visibility per state */
.mouth{display:none}
.s-idle .mouth-happy,.s-active .mouth-happy{display:block}
.s-thinking .mouth-neutral{display:block}
.s-working .mouth-neutral{display:block}
.s-speaking .mouth-speaking{display:block}
.s-notification .mouth-surprised{display:block}
.s-sleeping .mouth-sleepy{display:block}
.s-shy .mouth-shy{display:block}
.s-error .mouth-confused{display:block}

.eye-closed,.eye-happy,.eye-brow{display:none}
#blush ellipse{opacity:0;transition:opacity .4s}
.s-sleeping .eye-base,.s-sleeping .eye-shine{display:none}
.s-sleeping .eye-closed{display:block}
.s-shy .eye-base,.s-shy .eye-shine{display:none}
.s-shy .eye-happy{display:block}
.s-shy #blush ellipse{opacity:.85}
.s-error .eye-brow{display:block}

#thought-bubble{display:none}
.s-thinking #thought-bubble{display:block;animation:thoughtPop 1.6s ease-in-out infinite}
@keyframes thoughtPop{0%,100%{opacity:.4;transform:translateY(0)}50%{opacity:1;transform:translateY(-2px)}}

#notif-dot{display:none}
.s-notification #notif-dot{
  display:block;transform-box:fill-box;transform-origin:center;
  animation:notifPop .6s ease-out
}
@keyframes notifPop{0%{transform:scale(0)}60%{transform:scale(1.4)}100%{transform:scale(1)}}

.click-rip{
  position:absolute;width:80px;height:80px;border-radius:50%;
  border:2px solid var(--accent);top:50%;left:50%;
  animation:pulseRing .5s ease-out forwards;pointer-events:none;opacity:.7
}
@keyframes pulseRing{
  0%{opacity:.8;transform:translate(-50%,-50%) scale(1)}
  100%{opacity:0;transform:translate(-50%,-50%) scale(1.9)}
}

/* accent color overrides */
.eye-base,.gem-jade,.pendant-jade{fill:var(--accent)}
.mouth,.eye-closed,.eye-happy,.eye-brow{fill:none;stroke:var(--accent)}
.gem-glow{fill:var(--accent-soft)}
.center-glow{fill:var(--accent)}
.s-error .eye-brow,.s-error .mouth-confused{stroke:#FF8A7A}

/* ── breath scale on body (atop SMIL float translate) ──────────── */
#body-group{transform-box:fill-box;transform-origin:65px 110px;animation:breath 3.4s ease-in-out infinite}
.s-thinking #body-group,.s-working #body-group{animation:breath 1.7s ease-in-out infinite}
.s-sleeping #body-group{animation:breath 6.2s ease-in-out infinite}
.s-speaking #body-group{animation:breath 2.0s ease-in-out infinite}
.s-shy #body-group{animation:breath 2.4s ease-in-out infinite}
@keyframes breath{
  0%,100%{transform:scale(1,1)}
  50%{transform:scale(1.018,1.028)}
}

/* ── curious (mouseenter on robot window) ──────────────────────── */
.curious .eye-base{transform-box:fill-box;transform-origin:center;transform:scale(1.14);transition:transform .25s ease}
.curious .eye-shine{opacity:1;transition:opacity .2s}
.curious #head-gem .gem-glow{animation-duration:1.6s !important}

/* ── dizzy (rapid cursor sweep) ────────────────────────────────── */
.s-dizzy #robot-svg{animation:dizzyShake .55s ease-in-out 3}
.s-dizzy .eye-base,.s-dizzy .eye-shine{display:none}
.s-dizzy .eye-closed{display:block}
.s-dizzy .mouth-happy,.s-dizzy .mouth-neutral,.s-dizzy .mouth-speaking{display:none}
.s-dizzy .mouth-confused{display:block}
@keyframes dizzyShake{
  0%,100%{transform:rotate(0)}
  20%{transform:rotate(-9deg)}
  40%{transform:rotate(7deg)}
  60%{transform:rotate(-6deg)}
  80%{transform:rotate(4deg)}
}

/* ── thrown (fling release) ────────────────────────────────────── */
.s-thrown #body-group{animation:tumble .65s ease-in-out infinite}
.s-thrown .mouth-surprised{display:block}
.s-thrown .mouth-happy,.s-thrown .mouth-neutral{display:none}
@keyframes tumble{
  0%{transform:rotate(-14deg) scale(.98)}
  50%{transform:rotate(14deg) scale(1.02)}
  100%{transform:rotate(-14deg) scale(.98)}
}

/* ── idle ambient glow ─────────────────────────────────────────── */
.s-idle #head-gem .gem-glow{animation:ambientGlow 3.2s ease-in-out infinite}
@keyframes ambientGlow{
  0%,100%{opacity:.5;r:5.5}
  50%{opacity:.9;r:8}
}

/* ── mood: tired (long idle) ───────────────────────────────────── */
.mood-tired #robot-svg{filter:drop-shadow(0 8px 16px rgba(0,0,0,.45)) brightness(.88) saturate(.85)}
.mood-tired #head-gem .gem-glow{opacity:.35 !important}

/* ── particles (double-click flair) ────────────────────────────── */
.particle{
  position:absolute;pointer-events:none;left:50%;top:34%;
  font-size:20px;color:#FF8FB0;font-weight:700;
  text-shadow:0 0 10px rgba(255,143,176,.85);
  opacity:0;transform:translate(-50%,0);
  animation:floatUp 1.6s cubic-bezier(.2,.7,.3,1) forwards;
}
@keyframes floatUp{
  0%{opacity:0;transform:translate(-50%,4px) scale(.55)}
  18%{opacity:1;transform:translate(calc(-50% + var(--dx,0px)),-6px) scale(1.1)}
  100%{opacity:0;transform:translate(calc(-50% + var(--dx,0px)),-56px) scale(.7)}
}
</style>
</head>
<body>
<div id="wrap" class="s-idle">

<div id="rotate-wrap">
<svg id="robot-svg" viewBox="0 0 130 168" xmlns="http://www.w3.org/2000/svg">
<defs>
  <radialGradient id="bodyGrad" cx="40%" cy="32%" r="62%">
    <stop offset="0%" stop-color="#FFFCF5"/>
    <stop offset="60%" stop-color="#F2EBDA"/>
    <stop offset="100%" stop-color="#D8CFB8"/>
  </radialGradient>
  <radialGradient id="screenGrad" cx="50%" cy="38%" r="62%">
    <stop offset="0%" stop-color="#1c2530"/>
    <stop offset="70%" stop-color="#0d1218"/>
    <stop offset="100%" stop-color="#000"/>
  </radialGradient>
  <linearGradient id="goldGrad" x1="0%" y1="0%" x2="0%" y2="100%">
    <stop offset="0%" stop-color="#F4D58E"/>
    <stop offset="50%" stop-color="#D4A847"/>
    <stop offset="100%" stop-color="#8B6818"/>
  </linearGradient>
  <linearGradient id="screenReflect" x1="0%" y1="0%" x2="0%" y2="100%">
    <stop offset="0%" stop-color="rgba(255,255,255,.22)"/>
    <stop offset="50%" stop-color="rgba(255,255,255,.04)"/>
    <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
  </linearGradient>
  <filter id="eyeGlow" x="-50%" y="-50%" width="200%" height="200%">
    <feGaussianBlur stdDeviation="1.5" result="b"/>
    <feMerge><feMergeNode in="b"/><feMergeNode in="SourceGraphic"/></feMerge>
  </filter>
  <filter id="softGlow"><feGaussianBlur stdDeviation="2.5"/></filter>
  <filter id="shadowBlur"><feGaussianBlur stdDeviation="3"/></filter>
</defs>

<!-- ── FLOATING MIST ── -->
<g id="mist">
  <ellipse cx="52" cy="150" rx="14" ry="2.6" fill="rgba(255,255,255,.3)" filter="url(#softGlow)">
    <animate attributeName="cx" values="49;58;49" dur="5s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values=".35;.7;.35" dur="5s" repeatCount="indefinite"/>
  </ellipse>
  <ellipse cx="80" cy="153" rx="12" ry="2.2" fill="rgba(180,220,210,.25)" filter="url(#softGlow)">
    <animate attributeName="cx" values="83;74;83" dur="6s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values=".25;.6;.25" dur="6s" repeatCount="indefinite"/>
  </ellipse>
  <ellipse cx="65" cy="156" rx="16" ry="2" fill="rgba(255,255,255,.22)" filter="url(#softGlow)">
    <animate attributeName="cx" values="62;69;62" dur="4.5s" repeatCount="indefinite"/>
    <animate attributeName="opacity" values=".3;.65;.3" dur="4.5s" repeatCount="indefinite"/>
  </ellipse>
</g>

<!-- ── BASE (with SMIL float wrapper) ── -->
<g id="base-float">
  <animateTransform id="anim-base-float" attributeName="transform" type="translate"
                    values="0 0; 0 -3; 0 0" dur="3.6s" repeatCount="indefinite"/>
  <g id="base-group">
    <ellipse cx="65" cy="138" rx="28" ry="3.5" fill="rgba(0,0,0,.28)" filter="url(#shadowBlur)"/>
    <ellipse cx="65" cy="131" rx="27" ry="5.5" fill="#1a1d22"/>
    <ellipse cx="65" cy="130" rx="27" ry="5.5" fill="none" stroke="url(#goldGrad)" stroke-width="1.1"/>
    <!-- Concentric jade rings -->
    <ellipse cx="65" cy="129.5" rx="20" ry="3.2" fill="none" stroke="rgba(116,246,232,.2)" stroke-width=".5"/>
    <ellipse cx="65" cy="129" rx="14" ry="2.4" fill="none" stroke="rgba(116,246,232,.3)" stroke-width=".4"/>
    <ellipse class="gem-glow" cx="65" cy="128.5" rx="20" ry="2.6" filter="url(#softGlow)">
      <animate attributeName="opacity" values=".3;.8;.3" dur="2.8s" repeatCount="indefinite"/>
      <animate attributeName="rx" values="17;23;17" dur="2.8s" repeatCount="indefinite"/>
    </ellipse>
    <circle class="center-glow" cx="65" cy="129" r="1.6" opacity=".9"/>
  </g>
</g>

<!-- ── BODY (with SMIL float wrapper) ── -->
<g id="body-float">
  <animateTransform id="anim-body-float" attributeName="transform" type="translate"
                    values="0 0; 0 -8; 0 0" dur="3.6s" repeatCount="indefinite"/>
  <g id="body-group">

    <!-- BODY EGG -->
    <ellipse cx="65" cy="74" rx="40" ry="44" fill="url(#bodyGrad)" stroke="#C7BFA9" stroke-width=".5"/>
    <ellipse cx="50" cy="52" rx="18" ry="13" fill="rgba(255,255,255,.55)" transform="rotate(-15,50,52)"/>
    <ellipse cx="65" cy="104" rx="36" ry="14" fill="rgba(110,90,60,.07)"/>

    <!-- ARMS -->
    <ellipse cx="22" cy="86" rx="7" ry="11" fill="url(#bodyGrad)" stroke="#C7BFA9" stroke-width=".4" transform="rotate(-14,22,86)"/>
    <ellipse cx="20" cy="95" rx="5.6" ry="2" fill="url(#goldGrad)" transform="rotate(-14,20,95)"/>
    <ellipse cx="108" cy="86" rx="7" ry="11" fill="url(#bodyGrad)" stroke="#C7BFA9" stroke-width=".4" transform="rotate(14,108,86)"/>
    <ellipse cx="110" cy="95" rx="5.6" ry="2" fill="url(#goldGrad)" transform="rotate(14,110,95)"/>

    <!-- GOLD BELT -->
    <path d="M 28 96 Q 65 104 102 96 L 102 104 Q 65 112 28 104 Z" fill="url(#goldGrad)" stroke="#8B6818" stroke-width=".35"/>
    <path d="M 38 100 q 3 -2 6 0 q 3 -2 6 0 q 3 -2 6 0 q 3 -2 6 0 q 3 -2 6 0 q 3 -2 6 0 q 3 -2 6 0" stroke="#7a5810" stroke-width=".4" fill="none" opacity=".55"/>

    <!-- JADE PENDANT -->
    <g id="pendant">
      <path d="M 65 100 L 65 105" stroke="#8B6818" stroke-width=".7" opacity=".7"/>
      <circle cx="65" cy="111" r="6.2" class="pendant-jade" opacity=".85"/>
      <circle cx="65" cy="111" r="6.2" fill="none" stroke="url(#goldGrad)" stroke-width=".7"/>
      <circle cx="65" cy="111" r="1.3" fill="#0d1218" opacity=".35"/>
      <text x="65" y="113.4" text-anchor="middle" font-size="5" fill="#0d1218" font-family="'STKaiti','KaiTi','serif'" opacity=".75" font-weight="600">灵</text>
    </g>

    <!-- BLACK SCREEN FACE -->
    <rect x="33.5" y="40" width="63" height="46" rx="22" ry="22" fill="url(#goldGrad)" opacity=".9"/>
    <rect id="screen" x="35" y="41.5" width="60" height="43" rx="20.5" ry="20.5" fill="url(#screenGrad)"/>
    <ellipse cx="65" cy="50" rx="26" ry="9" fill="url(#screenReflect)" opacity=".8"/>

    <!-- EYES -->
    <g id="eyes">
      <g class="eye-group">
        <ellipse class="eye-base"  cx="51" cy="60" rx="5.4" ry="5.8" filter="url(#eyeGlow)"/>
        <ellipse class="eye-shine" cx="49.5" cy="58" rx="1.5" ry="2" fill="#FFFFFF" opacity=".9"/>
      </g>
      <g class="eye-group">
        <ellipse class="eye-base"  cx="79" cy="60" rx="5.4" ry="5.8" filter="url(#eyeGlow)"/>
        <ellipse class="eye-shine" cx="77.5" cy="58" rx="1.5" ry="2" fill="#FFFFFF" opacity=".9"/>
      </g>
      <path class="eye-closed" d="M 46 60 Q 51 63 56 60" stroke-width="1.5" stroke-linecap="round" filter="url(#eyeGlow)"/>
      <path class="eye-closed" d="M 74 60 Q 79 63 84 60" stroke-width="1.5" stroke-linecap="round" filter="url(#eyeGlow)"/>
      <path class="eye-happy" d="M 46 61 Q 51 56 56 61" stroke-width="1.5" stroke-linecap="round" filter="url(#eyeGlow)"/>
      <path class="eye-happy" d="M 74 61 Q 79 56 84 61" stroke-width="1.5" stroke-linecap="round" filter="url(#eyeGlow)"/>
      <path class="eye-brow" d="M 45 52 L 56 50" stroke-width="1.2" stroke-linecap="round" opacity=".75"/>
      <path class="eye-brow" d="M 74 50 L 85 52" stroke-width="1.2" stroke-linecap="round" opacity=".75"/>
    </g>

    <!-- BLUSH -->
    <g id="blush">
      <ellipse cx="42" cy="72" rx="3.2" ry="1.6" fill="#FF9DB7"/>
      <ellipse cx="88" cy="72" rx="3.2" ry="1.6" fill="#FF9DB7"/>
    </g>

    <!-- MOUTH -->
    <g id="mouth-group">
      <path class="mouth mouth-happy"     d="M 60 72 Q 65 77 70 72" stroke-width="1.3" stroke-linecap="round" filter="url(#eyeGlow)"/>
      <path class="mouth mouth-neutral"   d="M 61 73 L 69 73" stroke-width="1.1" stroke-linecap="round" filter="url(#eyeGlow)"/>
      <path class="mouth mouth-speaking"  d="M 60 72 Q 65 76 70 72 Q 65 74 60 72 Z" stroke="none" fill="var(--accent)" filter="url(#eyeGlow)"/>
      <circle class="mouth mouth-surprised" cx="65" cy="73" r="2.6" stroke="none" fill="var(--accent)" filter="url(#eyeGlow)"/>
      <path class="mouth mouth-sleepy"    d="M 61 73 L 69 73" stroke-width=".8" stroke-linecap="round" opacity=".5"/>
      <path class="mouth mouth-confused"  d="M 60 75 Q 65 70 70 75" stroke-width="1.2" stroke-linecap="round" filter="url(#eyeGlow)"/>
      <path class="mouth mouth-shy"       d="M 61 73 q 1.5 1.5 3 0 q 1.5 -1.5 3 0" stroke-width="1.1" stroke-linecap="round" filter="url(#eyeGlow)"/>
    </g>

    <!-- THINKING BUBBLE -->
    <g id="thought-bubble">
      <circle cx="98" cy="38" r="1.2" class="center-glow" opacity=".7"/>
      <circle cx="103" cy="33" r="1.6" class="center-glow" opacity=".8"/>
      <circle cx="109" cy="26" r="2.4" class="center-glow" opacity=".9" filter="url(#eyeGlow)"/>
    </g>

    <!-- NOTIFICATION DOT -->
    <circle id="notif-dot" cx="100" cy="36" r="4.5" fill="#FF6B6B" filter="url(#eyeGlow)"/>

    <!-- WORKING GEARS (visible in s-working) -->
    <g id="work-gears">
      <!-- Left gear -->
      <g id="gear-l" filter="url(#eyeGlow)">
        <circle cx="38" cy="34" r="4.5" class="center-glow" opacity=".85"/>
        <circle cx="38" cy="34" r="1.6" fill="#0d1218"/>
        <g fill="var(--accent)" opacity=".85">
          <rect x="36.6" y="27.5" width="2.8" height="3" rx=".4"/>
          <rect x="36.6" y="37.5" width="2.8" height="3" rx=".4"/>
          <rect x="31.5" y="32.6" width="3" height="2.8" rx=".4"/>
          <rect x="41.5" y="32.6" width="3" height="2.8" rx=".4"/>
          <rect x="32.7" y="28.5" width="2.5" height="2.8" rx=".4" transform="rotate(-45,33.95,29.9)"/>
          <rect x="40.7" y="28.5" width="2.5" height="2.8" rx=".4" transform="rotate(45,41.95,29.9)"/>
          <rect x="32.7" y="37" width="2.5" height="2.8" rx=".4" transform="rotate(45,33.95,38.4)"/>
          <rect x="40.7" y="37" width="2.5" height="2.8" rx=".4" transform="rotate(-45,41.95,38.4)"/>
        </g>
      </g>
      <!-- Right gear (smaller) -->
      <g id="gear-r" filter="url(#eyeGlow)">
        <circle cx="92" cy="36" r="3.2" class="center-glow" opacity=".85"/>
        <circle cx="92" cy="36" r="1.1" fill="#0d1218"/>
        <g fill="var(--accent)" opacity=".85">
          <rect x="91" y="30.5" width="2" height="2.4" rx=".3"/>
          <rect x="91" y="39.1" width="2" height="2.4" rx=".3"/>
          <rect x="86.6" y="35" width="2.4" height="2" rx=".3"/>
          <rect x="95" y="35" width="2.4" height="2" rx=".3"/>
        </g>
      </g>
    </g>

    <!-- HEAD GEM + CROWN -->
    <g id="head-gem">
      <!-- Glow pulse -->
      <circle class="gem-glow" cx="65" cy="16" r="7">
        <animate attributeName="opacity" values=".4;.95;.4" dur="2.6s" repeatCount="indefinite"/>
        <animate attributeName="r" values="5.5;9;5.5" dur="2.6s" repeatCount="indefinite"/>
      </circle>
      <!-- Crown base ring -->
      <ellipse cx="65" cy="32" rx="9" ry="2.8" fill="url(#goldGrad)"/>
      <!-- Crown spikes (6 spikes matching showcase design) -->
      <path d="M 56 31 L 54 18 L 60 28 Z" fill="url(#goldGrad)" stroke="#8B6818" stroke-width=".25"/>
      <path d="M 60 30 L 59 12 L 64 27 Z" fill="url(#goldGrad)" stroke="#8B6818" stroke-width=".25"/>
      <path d="M 65 30 L 65 8 L 70 27 Z" fill="url(#goldGrad)" stroke="#8B6818" stroke-width=".3"/>
      <path d="M 70 30 L 71 12 L 66 27 Z" fill="url(#goldGrad)" stroke="#8B6818" stroke-width=".25"/>
      <path d="M 74 31 L 76 18 L 70 28 Z" fill="url(#goldGrad)" stroke="#8B6818" stroke-width=".25"/>
      <!-- Central jade gem -->
      <path d="M 65 6 Q 72 16 65 25 Q 58 16 65 6 Z" class="gem-jade" stroke="#1F6E5E" stroke-width=".35"/>
      <ellipse cx="62.5" cy="13" rx="1.5" ry="2.8" fill="rgba(255,255,255,.65)" transform="rotate(-12,62.5,13)"/>
    </g>

    <!-- RIBBONS (SMIL rotate sway) -->
    <g id="ribbons">
      <path d="M 56 32 Q 50 42 52 50 Q 54 56 50 60" stroke="url(#goldGrad)" stroke-width="1.4" fill="none" stroke-linecap="round" opacity=".9">
        <animateTransform attributeName="transform" type="rotate" values="-3 56 32; 7 56 32; -3 56 32" dur="3.2s" repeatCount="indefinite"/>
      </path>
      <path d="M 74 32 Q 80 42 78 50 Q 76 56 80 60" stroke="url(#goldGrad)" stroke-width="1.4" fill="none" stroke-linecap="round" opacity=".9">
        <animateTransform attributeName="transform" type="rotate" values="3 74 32; -7 74 32; 3 74 32" dur="3.2s" repeatCount="indefinite"/>
      </path>
      <circle cx="50" cy="60" r="1.5" fill="url(#goldGrad)">
        <animateTransform attributeName="transform" type="rotate" values="-3 56 32; 7 56 32; -3 56 32" dur="3.2s" repeatCount="indefinite"/>
      </circle>
      <circle cx="80" cy="60" r="1.5" fill="url(#goldGrad)">
        <animateTransform attributeName="transform" type="rotate" values="3 74 32; -7 74 32; 3 74 32" dur="3.2s" repeatCount="indefinite"/>
      </circle>
    </g>

  </g>
</g>

</svg>
</div>
</div>

<script>
const wrap = document.getElementById('wrap');
const robotSvg = document.getElementById('robot-svg');
const rotateWrap = document.getElementById('rotate-wrap');
const animBodyFloat = document.getElementById('anim-body-float');
const animBaseFloat = document.getElementById('anim-base-float');

let state = 'idle', sleepTimer = null;
let dragging = false, dist = 0;
let sx = 0, sy = 0, wx = 0, wy = 0;
let peekClass = '';
const auxClasses = new Set();   // hover/mood/etc. — survive setState
let pendingClickTimer = null;
let dizzyTimer = null;
let dragHistory = [];           // {x,y,t} for fling velocity
let rotY = 0, targetRotY = 0;  // pseudo-3D rotation

const W = 150, H = 180;

// state → breathing duration (still drives SMIL float)
const FLOAT_DUR = {
  idle:'3.6s', active:'2.4s', thinking:'1.6s', working:'1.4s',
  speaking:'2.0s', sleeping:'6.5s', notification:'2.4s',
  error:'2.4s', shy:'2.6s', dizzy:'2.0s', thrown:'.9s'
};

function applyClasses() {
  const cls = [];
  if (dragging) cls.push('dragging');
  if (peekClass) cls.push(peekClass);
  auxClasses.forEach(c => cls.push(c));
  cls.push('s-' + state);
  wrap.className = cls.join(' ');
}

function setState(s) {
  if (dragging && (s === 'idle' || s === 'sleeping')) return;
  state = s;
  applyClasses();

  if (FLOAT_DUR[s] && animBodyFloat) {
    animBodyFloat.setAttribute('dur', FLOAT_DUR[s]);
    animBaseFloat.setAttribute('dur', FLOAT_DUR[s]);
  }

  clearTimeout(sleepTimer);
  if (s !== 'sleeping' && !dragging)
    sleepTimer = setTimeout(() => setState('sleeping'), 300000);
}

function setPeek(side) {
  peekClass = side ? 'peek-' + side : '';
  applyClasses();
}

// ── Pseudo-3D rotation ───────────────────────────────────────────
function animateRotation() {
  rotY += (targetRotY - rotY) * 0.12;
  if (Math.abs(rotY) < 0.1) rotY = 0;
  if (!dragging || dist < 4) {
    targetRotY *= 0.92; // spring back when not dragging
  }
  const rx = rotY * 0.15; // slight X rotation for depth
  rotateWrap.style.transform = `rotateY(${rotY.toFixed(1)}deg) rotateX(${rx.toFixed(1)}deg)`;
  requestAnimationFrame(animateRotation);
}
requestAnimationFrame(animateRotation);

// ── Eye tracking ─────────────────────────────────────────────────
const shines = document.querySelectorAll('.eye-shine');
const pupils = document.querySelectorAll('.eye-base');
const shineBase = [{ cx: 49.5, cy: 58 }, { cx: 77.5, cy: 58 }];
const pupilBase = [{ cx: 51,   cy: 60 }, { cx: 79,   cy: 60 }];
let targetOx = 0, targetOy = 0, curOx = 0, curOy = 0;

function trackEyes(clientX, clientY) {
  const cx = W / 2, cy = H / 2;
  const dx = clientX - cx;
  const dy = clientY - cy;
  const d = Math.hypot(dx, dy) || 1;
  const maxR = 2.2;
  const damp = Math.min(1, d / 220);
  targetOx = (dx / d) * maxR * damp;
  targetOy = (dy / d) * maxR * damp * 0.85;
}

function animateEyes() {
  curOx += (targetOx - curOx) * 0.18;
  curOy += (targetOy - curOy) * 0.18;
  shines.forEach((el, i) => {
    el.setAttribute('cx', (shineBase[i].cx + curOx * 1.5).toFixed(2));
    el.setAttribute('cy', (shineBase[i].cy + curOy * 1.5).toFixed(2));
  });
  pupils.forEach((el, i) => {
    el.setAttribute('cx', (pupilBase[i].cx + curOx * 0.85).toFixed(2));
    el.setAttribute('cy', (pupilBase[i].cy + curOy * 0.85).toFixed(2));
  });
  requestAnimationFrame(animateEyes);
}
requestAnimationFrame(animateEyes);

// In-window cursor fallback
document.addEventListener('mousemove', e => {
  if (dragging) return;
  trackEyes(e.clientX, e.clientY);
});

// ── Dizzy: global cursor sweep detection ─────────────────────────
let lastCursorTs = 0;
let lastCursorPos = null;
let sweepHits = 0;
let lastSweepTs = 0;

function handleGlobalCursor(p) {
  if (dragging) return;             // drag owns the compositor — skip eye work entirely
  trackEyes(p.x, p.y);
  if (state === 'dizzy' || state === 'thrown') return;
  const now = performance.now();
  if (lastCursorPos && lastCursorTs) {
    const dt = now - lastCursorTs;
    if (dt > 0 && dt < 120) {
      const ddx = p.x - lastCursorPos.x;
      const ddy = p.y - lastCursorPos.y;
      const v = Math.hypot(ddx, ddy) / dt;   // px/ms
      const inRobot = p.x >= -10 && p.x <= W + 10 && p.y >= -10 && p.y <= H + 10;
      if (inRobot && v > 1.5) {
        if (now - lastSweepTs > 70) {
          sweepHits += 1;
          lastSweepTs = now;
          if (sweepHits >= 6) {
            sweepHits = 0;
            triggerDizzy();
          }
        }
      }
    }
  }
  // decay sweep count when calm
  if (now - lastSweepTs > 900) sweepHits = 0;
  lastCursorPos = p;
  lastCursorTs = now;
}

function triggerDizzy() {
  setState('dizzy');
  clearTimeout(dizzyTimer);
  dizzyTimer = setTimeout(() => { if (state === 'dizzy') setState('idle'); }, 2400);
}

// ── Drag, fling-throw, click, double-click ───────────────────────
wrap.addEventListener('mousedown', e => {
  if (e.button !== 0) return;
  dragging = true; dist = 0;
  sx = e.screenX; sy = e.screenY;
  wx = window.screenX; wy = window.screenY;
  dragHistory = [{ x: e.screenX, y: e.screenY, t: performance.now() }];
  wrap.classList.add('dragging');
  if (peekClass) peekClass = '';
  // suspend SMIL for crisp drag
  if (robotSvg && robotSvg.pauseAnimations) robotSvg.pauseAnimations();
});

let pendingMove = null;
let moveRafId = 0;
function flushMove() {
  moveRafId = 0;
  if (!pendingMove || !dragging) { pendingMove = null; return; }
  window.robot.moveWindow(pendingMove.x, pendingMove.y);
  pendingMove = null;
}

document.addEventListener('mousemove', e => {
  if (!dragging) return;
  dist += Math.abs(e.movementX || 0) + Math.abs(e.movementY || 0);
  if (dist < 4) return;
  const nx = wx + (e.screenX - sx);
  const ny = wy + (e.screenY - sy);
  pendingMove = { x: Math.round(nx), y: Math.round(ny) };
  // Pseudo-3D: horizontal drag rotates the robot
  targetRotY = Math.max(-35, Math.min(35, (e.screenX - sx) * 0.3));
  dragHistory.push({ x: e.screenX, y: e.screenY, t: performance.now() });
  if (dragHistory.length > 6) dragHistory.shift();
  if (!moveRafId) moveRafId = requestAnimationFrame(flushMove);
});

document.addEventListener('mouseup', () => {
  if (!dragging) return;
  // commit any pending rAF-batched move before releasing
  if (moveRafId) { cancelAnimationFrame(moveRafId); moveRafId = 0; }
  if (pendingMove) { window.robot.moveWindow(pendingMove.x, pendingMove.y); pendingMove = null; }
  // Fling rotation: carry momentum from drag velocity
  if (dragHistory.length >= 2) {
    const recent = dragHistory.slice(-3);
    const dx = recent[recent.length - 1].x - recent[0].x;
    targetRotY = Math.max(-45, Math.min(45, targetRotY + dx * 0.15));
  }
  dragging = false;
  wrap.classList.remove('dragging');
  if (robotSvg && robotSvg.unpauseAnimations) robotSvg.unpauseAnimations();

  if (dist < 4) {
    // single click → ripple + delayed chat toggle (cancel if dblclick)
    const r = document.createElement('div');
    r.className = 'click-rip'; wrap.appendChild(r);
    setTimeout(() => r.remove(), 500);
    clearTimeout(pendingClickTimer);
    pendingClickTimer = setTimeout(() => {
      pendingClickTimer = null;
      window.robot.toggleChat();
      if (state === 'sleeping' || state === 'idle') setState('active');
    }, 230);
  } else {
    // measure fling velocity from last 2-4 samples
    let vx = 0, vy = 0;
    if (dragHistory.length >= 2) {
      const recent = dragHistory.slice(-4);
      const first = recent[0], last = recent[recent.length - 1];
      const dt = last.t - first.t;
      if (dt > 0 && dt < 220) {
        vx = (last.x - first.x) / dt * 16;
        vy = (last.y - first.y) / dt * 16;
      }
    }
    const speed = Math.hypot(vx, vy);
    if (speed > 7) {
      setState('thrown');
      if (window.robot.throwFrom) window.robot.throwFrom(vx, vy);
      // safety fallback — main hard-caps physics at 6s, give the visual a hair more
      setTimeout(() => { if (state === 'thrown') setState('idle'); }, 6500);
    } else {
      window.robot.notifyMoved();
      setState('active');
    }
  }
  dragHistory = [];
  clearTimeout(sleepTimer);
  if (state !== 'thrown') sleepTimer = setTimeout(() => setState('sleeping'), 300000);
});

// ── Hover-curious ────────────────────────────────────────────────
wrap.addEventListener('mouseenter', () => {
  if (dragging) return;
  if (state === 'sleeping' || state === 'thrown' || state === 'dizzy') return;
  auxClasses.add('curious');
  applyClasses();
});
wrap.addEventListener('mouseleave', () => {
  auxClasses.delete('curious');
  applyClasses();
});

// ── Double-click signature: shy + heart particles ────────────────
const PARTICLES = ['♡', '✦', '✨', '♥'];
function spawnParticles() {
  const colors = ['#FF8FB0', '#FFD580', '#A8E6FF', '#FFA6E6'];
  const n = 5;
  for (let i = 0; i < n; i++) {
    const p = document.createElement('div');
    p.className = 'particle';
    p.textContent = PARTICLES[Math.floor(Math.random() * PARTICLES.length)];
    p.style.color = colors[i % colors.length];
    p.style.setProperty('--dx', (Math.random() * 60 - 30).toFixed(0) + 'px');
    p.style.animationDelay = (i * 70) + 'ms';
    p.style.left = (40 + Math.random() * 20) + '%';
    wrap.appendChild(p);
    setTimeout(() => p.remove(), 1700 + i * 70);
  }
}

wrap.addEventListener('dblclick', e => {
  e.preventDefault();
  e.stopPropagation();
  // cancel the pending single-click chat-toggle
  if (pendingClickTimer) { clearTimeout(pendingClickTimer); pendingClickTimer = null; }
  spawnParticles();
  const prev = state;
  setState('shy');
  setTimeout(() => { if (state === 'shy') setState(prev === 'sleeping' || prev === 'shy' ? 'idle' : prev); }, 2400);
});

// ── Hooks from main process ─────────────────────────────────────
function applyAccent(color, soft) {
  document.documentElement.style.setProperty('--accent', color);
  if (soft) document.documentElement.style.setProperty('--accent-soft', soft);
}

window.robot.onSetState(s => setState(s));
window.robot.onTriggerPulse(() => setState('active'));
if (window.robot.onSetAccent) window.robot.onSetAccent(({ color, soft }) => applyAccent(color, soft));
if (window.robot.onCursorPoint) window.robot.onCursorPoint(p => handleGlobalCursor(p));
if (window.robot.onSetPeek) window.robot.onSetPeek(side => setPeek(side));
if (window.robot.onSetMood) window.robot.onSetMood(m => {
  if (m && m.tired) auxClasses.add('mood-tired'); else auxClasses.delete('mood-tired');
  applyClasses();
});

// ── Idle life system ─────────────────────────────────────────────
const MICRO_ACTIONS = [
  'mc-lookup','mc-lookdown','mc-wink-l','mc-wink-r',
  'mc-tilt','mc-tilt-r','mc-bob','mc-nod',
  'mc-look-left','mc-look-right','mc-curious','mc-yawn'
];
let microTimer = null;
let idleSwayTimer = null;
let blinkTimer = null;

// Frequent micro-actions (8-20s)
function scheduleMicro() {
  clearTimeout(microTimer);
  const delay = 8000 + Math.random() * 12000;
  microTimer = setTimeout(() => {
    if (state === 'idle' && !dragging) {
      const cls = MICRO_ACTIONS[Math.floor(Math.random() * MICRO_ACTIONS.length)];
      wrap.classList.add(cls);
      const dur = cls === 'mc-yawn' ? 1800 : 1200;
      setTimeout(() => wrap.classList.remove(cls), dur);
    }
    scheduleMicro();
  }, delay);
}

// Random blinking (3-8s interval, more natural)
function scheduleBlink() {
  clearTimeout(blinkTimer);
  const delay = 3000 + Math.random() * 5000;
  blinkTimer = setTimeout(() => {
    if (state === 'idle' && !dragging) {
      const eyes = document.querySelectorAll('.eye-base, .eye-shine');
      eyes.forEach(e => {
        e.style.transition = 'transform .08s';
        e.style.transformBox = 'fill-box';
        e.style.transformOrigin = 'center';
        e.style.transform = 'scaleY(0.1)';
      });
      setTimeout(() => {
        eyes.forEach(e => { e.style.transform = ''; e.style.transition = ''; });
      }, 120);
    }
    scheduleBlink();
  }, delay);
}

// Gentle idle sway every 6-12s
function scheduleSway() {
  clearTimeout(idleSwayTimer);
  const delay = 6000 + Math.random() * 6000;
  idleSwayTimer = setTimeout(() => {
    if (state === 'idle' && !dragging) {
      const angle = (Math.random() - 0.5) * 4; // -2 to 2 deg
      robotSvg.style.transition = 'transform 1.2s ease-in-out';
      robotSvg.style.transformOrigin = '50% 85%';
      robotSvg.style.transform = `rotate(${angle}deg)`;
      setTimeout(() => {
        robotSvg.style.transform = 'rotate(0deg)';
        setTimeout(() => { robotSvg.style.transition = ''; }, 1200);
      }, 1200);
    }
    scheduleSway();
  }, delay);
}

scheduleMicro();
scheduleBlink();
scheduleSway();

// ── First-launch hero animation ──────────────────────────────────
(async () => {
  if (!window.robot.getFirstLaunch) { setState('idle'); return; }
  try {
    const first = await window.robot.getFirstLaunch();
    if (first) {
      setState('hero');
      setTimeout(() => setState('idle'), 2800);
    } else {
      setState('idle');
    }
  } catch (_) { setState('idle'); }
})();
</script>
</body>
</html>
