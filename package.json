{
  "name": "robot-agent",
  "version": "1.1.0",
  "description": "Floating AI Robot Agent Desktop App",
  "author": "74593abc-sudo",
  "license": "AGPL-3.0-only",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node __tests__/_run-no-jest.js",
    "test:jest": "jest --passWithNoTests",
    "build:win": "electron-builder --win --x64"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.robotagent.app",
    "productName": "灵珑 LingLong",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ],
    "files": [
      "**/*",
      "!node_modules/.bin",
      "!dist/**",
      "!**/*.png",
      "!_*.ps1",
      "!_*.log",
      "!electron-*.log",
      "!electron-log.txt",
      "!_verify/**",
      "!_peek/**",
      "!_szchk/**",
      "!.claude/**",
      "!scripts/**",
      "!__tests__/**",
      "!docs/**",
      "!*.md",
      "!audit-reports/**",
      "!backups/**",
      "!LICENSE"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "灵珑 LingLong",
      "artifactName": "LingLong-Setup-${version}.${ext}"
    }
  }
}
